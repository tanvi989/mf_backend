# Copy to .env and fill in. Never commit .env or secrets/*.json

MONGODB_URI=mongodb+srv://USER:PASS@cluster.example.mongodb.net/?appName=myapp
MONGODB_DB_NAME=my_database

GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/secrets/gcs-service-account.json
GCP_PROJECT_ID=your-gcp-project
BUCKET_NAME=your-bucket
FOLDER_NAME=vto

GEMINI_API_KEY=
GOOGLE_API_KEY=
